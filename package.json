{
  "name": "arcane-extension",
  "private": true,
  "scripts": {
    "check:be:lint": "uv run ruff check h_arcane",
    "check:be:type": "uv run ty check h_arcane",
    "check:be": "pnpm run check:be:lint && pnpm run check:be:type",
    "test:be:state": "uv run pytest tests/state -q",
    "test:be:e2e": "uv run pytest tests/e2e -v",
    "check:fe:lint": "pnpm -C arcane-dashboard run lint",
    "check:fe:type": "pnpm -C arcane-dashboard run typecheck",
    "check:fe": "pnpm run check:fe:lint && pnpm run check:fe:type",
    "test:fe:e2e": "pnpm -C arcane-dashboard run e2e",
    "test:fe:e2e:live": "pnpm -C arcane-dashboard run e2e:live",
    "check:fast": "pnpm run check:be && pnpm run check:fe",
    "test:be:fast": "pnpm run test:be:state"
  },
  "packageManager": "pnpm@10.17.1+sha512.17c560fca4867ae9473a3899ad84a88334914f379be46d455cbf92e5cf4b39d34985d452d2583baf19967fa76cb5c17bc9e245529d0b98745721aa7200ecaf7a"
}
