{
  "name": "ergon-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch server.ts",
    "dev:test": "tsx server.ts",
    "build": "next build",
    "start": "NODE_ENV=production tsx server.ts",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "generate:contracts:schemas": "PYTHONPATH=.. python ../scripts/export_contract_schemas.py",
    "generate:contracts:rest": "openapi-zod-client ./src/generated/rest/openapi.json -o ./src/generated/rest/contracts.ts --export-schemas && node ./scripts/generate-rest-contracts.mjs",
    "generate:contracts:events": "node ./scripts/generate-event-contracts.mjs",
    "generate:contracts": "pnpm run generate:contracts:schemas && pnpm run generate:contracts:rest && pnpm run generate:contracts:events",
    "test:contracts": "tsx --test tests/contracts/contracts.test.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:live": "PLAYWRIGHT_LIVE=1 playwright test tests/e2e/live.smoke.spec.ts"
  },
  "dependencies": {
    "@types/dagre": "^0.7.53",
    "@xyflow/react": "^12.10.0",
    "dagre": "^0.8.5",
    "inngest": "^3.49.3",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/ws": "^8.18.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "json-schema-to-zod": "^2.7.0",
    "openapi-zod-client": "^1.18.3",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.17.1+sha512.17c560fca4867ae9473a3899ad84a88334914f379be46d455cbf92e5cf4b39d34985d452d2583baf19967fa76cb5c17bc9e245529d0b98745721aa7200ecaf7a"
}
