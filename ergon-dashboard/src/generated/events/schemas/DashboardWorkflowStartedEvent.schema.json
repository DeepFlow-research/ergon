{
  "$defs": {
    "AssistantTextPart": {
      "properties": {
        "part_kind": {
          "const": "assistant_text",
          "default": "assistant_text",
          "description": "Discriminator identifying this context part as assistant text.",
          "title": "Part Kind",
          "type": "string"
        },
        "content": {
          "description": "Assistant response text emitted by the worker.",
          "title": "Content",
          "type": "string"
        }
      },
      "required": [
        "content"
      ],
      "title": "AssistantTextPart",
      "type": "object"
    },
    "ContextPartChunkLog": {
      "description": "Core-enriched context stream item suitable for API/dashboard projection.",
      "properties": {
        "part": {
          "description": "Typed context stream payload.",
          "discriminator": {
            "mapping": {
              "assistant_text": "#/$defs/AssistantTextPart",
              "system_prompt": "#/$defs/SystemPromptPart",
              "thinking": "#/$defs/ThinkingPart",
              "tool_call": "#/$defs/ToolCallPart",
              "tool_result": "#/$defs/ToolResultPart",
              "user_message": "#/$defs/UserMessagePart"
            },
            "propertyName": "part_kind"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/SystemPromptPart"
            },
            {
              "$ref": "#/$defs/UserMessagePart"
            },
            {
              "$ref": "#/$defs/AssistantTextPart"
            },
            {
              "$ref": "#/$defs/ToolCallPart"
            },
            {
              "$ref": "#/$defs/ToolResultPart"
            },
            {
              "$ref": "#/$defs/ThinkingPart"
            }
          ],
          "title": "Part"
        },
        "token_ids": {
          "anyOf": [
            {
              "items": {
                "type": "integer"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Token IDs associated with this context part when provided by the backend.",
          "title": "Token Ids"
        },
        "logprobs": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/TokenLogprob"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Per-token log probabilities associated with this context part.",
          "title": "Logprobs"
        },
        "sequence": {
          "description": "Monotonic sequence number within the execution stream.",
          "title": "Sequence",
          "type": "integer"
        },
        "worker_binding_key": {
          "description": "Worker binding that emitted this context part.",
          "title": "Worker Binding Key",
          "type": "string"
        },
        "turn_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Stable generation turn identifier shared by related streamed parts.",
          "title": "Turn Id"
        },
        "started_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Timestamp when generation for this part started.",
          "title": "Started At"
        },
        "completed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Timestamp when generation for this part completed.",
          "title": "Completed At"
        },
        "policy_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional worker or policy version that produced the part.",
          "title": "Policy Version"
        }
      },
      "required": [
        "part",
        "sequence",
        "worker_binding_key"
      ],
      "title": "ContextPartChunkLog",
      "type": "object"
    },
    "JsonObject": {
      "additionalProperties": {
        "$ref": "#/$defs/JsonValue"
      },
      "type": "object"
    },
    "JsonScalar": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
