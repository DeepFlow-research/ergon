{
  "$defs": {
    "TaskTreeNode": {
      "description": "Recursive task tree node embedded in workflow.started.\n\nShape matches the dashboard Zod ``TaskTreeNodeSchema``.  Built from\n``RunGraphNode`` + ``RunGraphEdge`` + ``ExperimentDefinitionWorker``\nat emit time; see ``start_workflow._build_task_tree_for_run``.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "assigned_to": {
          "$ref": "#/$defs/WorkerRef"
        },
        "children": {
          "default": [],
          "items": {
            "$ref": "#/$defs/TaskTreeNode"
          },
          "title": "Children",
          "type": "array"
        },
        "depends_on": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Depends On",
          "type": "array"
        },
        "is_leaf": {
          "title": "Is Leaf",
          "type": "boolean"
        },
        "resources": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Resources",
          "type": "array"
        },
        "parent_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent Id"
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "assigned_to",
        "is_leaf"
      ],
      "title": "TaskTreeNode",
      "type": "object"
    },
    "WorkerRef": {
      "description": "Reference to an ``ExperimentDefinitionWorker`` row as seen by the\ndashboard \u2014 matches the Zod ``WorkerRefSchema``.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "type": {
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "type"
      ],
      "title": "WorkerRef",
      "type": "object"
    }
  },
  "additionalProperties": true,
  "properties": {
    "run_id": {
      "format": "uuid",
      "title": "Run Id",
      "type": "string"
    },
    "experiment_id": {
      "format": "uuid",
      "title": "Experiment Id",
      "type": "string"
    },
    "workflow_name": {
      "title": "Workflow Name",
      "type": "string"
    },
    "task_tree": {
      "$ref": "#/$defs/TaskTreeNode"
    },
    "started_at": {
      "format": "date-time",
      "title": "Started At",
      "type": "string"
    },
    "total_tasks": {
      "title": "Total Tasks",
      "type": "integer"
    },
    "total_leaf_tasks": {
      "title": "Total Leaf Tasks",
      "type": "integer"
    }
  },
  "required": [
    "run_id",
    "experiment_id",
    "workflow_name",
    "task_tree",
    "started_at",
    "total_tasks",
    "total_leaf_tasks"
  ],
  "title": "DashboardWorkflowStartedEvent",
  "type": "object"
}
