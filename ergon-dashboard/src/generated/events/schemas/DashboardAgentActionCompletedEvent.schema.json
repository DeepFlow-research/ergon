      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Action Output"
    },
    "action_type": {
      "title": "Action Type",
      "type": "string"
    },
    "duration_ms": {
