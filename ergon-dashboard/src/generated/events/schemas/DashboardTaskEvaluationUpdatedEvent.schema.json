{
  "$defs": {
    "RunEvaluationCriterionDto": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "stageNum": {
          "title": "Stagenum",
          "type": "integer"
        },
        "stageName": {
          "title": "Stagename",
          "type": "string"
        },
        "criterionNum": {
          "title": "Criterionnum",
          "type": "integer"
        },
        "criterionType": {
          "title": "Criteriontype",
          "type": "string"
        },
        "criterionDescription": {
          "title": "Criteriondescription",
          "type": "string"
        },
        "criterionName": {
          "title": "Criterionname",
          "type": "string"
        },
        "status": {
          "enum": [
            "passed",
            "failed",
            "errored",
            "skipped"
          ],
          "title": "Status",
          "type": "string"
        },
        "passed": {
          "title": "Passed",
          "type": "boolean"
        },
        "weight": {
          "title": "Weight",
          "type": "number"
        },
        "contribution": {
          "title": "Contribution",
          "type": "number"
        },
        "evaluationInput": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evaluationinput"
        },
        "score": {
          "title": "Score",
          "type": "number"
        },
        "maxScore": {
          "title": "Maxscore",
          "type": "number"
        },
        "feedback": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Feedback"
        },
        "modelReasoning": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Modelreasoning"
        },
        "skippedReason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Skippedreason"
        },
        "evaluatedActionIds": {
          "items": {
            "type": "string"
          },
          "title": "Evaluatedactionids",
          "type": "array"
        },
        "evaluatedResourceIds": {
          "items": {
            "type": "string"
          },
          "title": "Evaluatedresourceids",
          "type": "array"
        },
        "error": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error"
        }
      },
      "required": [
        "id",
        "stageNum",
        "stageName",
        "criterionNum",
        "criterionType",
        "criterionDescription",
        "criterionName",
        "status",
        "passed",
        "weight",
        "contribution",
        "score",
        "maxScore"
      ],
      "title": "RunEvaluationCriterionDto",
      "type": "object"
    },
    "RunTaskEvaluationDto": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "runId": {
          "title": "Runid",
          "type": "string"
        },
        "taskId": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Taskid"
        },
        "evaluatorName": {
          "title": "Evaluatorname",
          "type": "string"
        },
        "aggregationRule": {
          "title": "Aggregationrule",
          "type": "string"
        },
        "totalScore": {
          "title": "Totalscore",
          "type": "number"
        },
        "maxScore": {
          "title": "Maxscore",
          "type": "number"
        },
        "normalizedScore": {
          "title": "Normalizedscore",
          "type": "number"
        },
        "stagesEvaluated": {
          "title": "Stagesevaluated",
          "type": "integer"
        },
        "stagesPassed": {
          "title": "Stagespassed",
          "type": "integer"
        },
        "failedGate": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Failedgate"
        },
        "createdAt": {
          "format": "date-time",
          "title": "Createdat",
          "type": "string"
        },
        "criterionResults": {
          "items": {
            "$ref": "#/$defs/RunEvaluationCriterionDto"
          },
          "title": "Criterionresults",
          "type": "array"
        }
      },
      "required": [
        "id",
        "runId",
        "evaluatorName",
        "aggregationRule",
        "totalScore",
        "maxScore",
        "normalizedScore",
        "stagesEvaluated",
        "stagesPassed",
        "createdAt"
      ],
      "title": "RunTaskEvaluationDto",
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "Embeds the full RunTaskEvaluationDto as ``evaluation``.",
  "properties": {
    "run_id": {
      "format": "uuid",
      "title": "Run Id",
      "type": "string"
    },
    "task_id": {
      "format": "uuid",
      "title": "Task Id",
      "type": "string"
    },
    "evaluation": {
      "$ref": "#/$defs/RunTaskEvaluationDto"
    }
  },
  "required": [
    "run_id",
    "task_id",
    "evaluation"
  ],
  "title": "DashboardTaskEvaluationUpdatedEvent",
  "type": "object"
}
