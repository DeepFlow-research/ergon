{
  "$defs": {
    "CohortMetadataSummaryDto": {
      "description": "Typed reproducibility metadata exposed to the frontend.",
      "properties": {
        "code_commit_sha": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Code Commit Sha"
        },
        "dispatch_config": {
          "$ref": "#/$defs/DispatchConfigSnapshot"
        },
        "model_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model Name"
        },
        "model_provider": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model Provider"
        },
        "prompt_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prompt Version"
        },
        "repo_dirty": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Repo Dirty"
        },
        "sandbox_config": {
          "$ref": "#/$defs/SandboxConfigSnapshot"
        },
        "worker_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Worker Version"
        }
      },
      "title": "CohortMetadataSummaryDto",
      "type": "object"
    },
    "CohortStatsExtras": {
      "description": "Optional typed extension point for cohort aggregate metrics.",
      "properties": {
        "benchmark_counts": {
          "additionalProperties": {
            "type": "integer"
          },
          "title": "Benchmark Counts",
          "type": "object"
        },
        "latest_run_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Latest Run At"
        }
      },
      "title": "CohortStatsExtras",
      "type": "object"
    },
    "CohortStatusCountsDto": {
      "description": "Aggregate run counts by lifecycle status.",
      "properties": {
        "completed": {
          "default": 0,
          "title": "Completed",
          "type": "integer"
        },
        "evaluating": {
          "default": 0,
          "title": "Evaluating",
          "type": "integer"
        },
        "executing": {
          "default": 0,
          "title": "Executing",
          "type": "integer"
        },
        "failed": {
          "default": 0,
          "title": "Failed",
          "type": "integer"
        },
        "pending": {
          "default": 0,
          "title": "Pending",
          "type": "integer"
        }
      },
      "title": "CohortStatusCountsDto",
      "type": "object"
    },
    "CohortSummaryDto": {
      "description": "Summary row for cohort list and live updates.",
      "properties": {
        "average_duration_ms": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Average Duration Ms"
        },
        "average_score": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Average Score"
        },
        "best_score": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Best Score"
        },
        "cohort_id": {
          "format": "uuid",
          "title": "Cohort Id",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "created_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Created By"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "extras": {
          "$ref": "#/$defs/CohortStatsExtras"
        },
        "failure_rate": {
          "default": 0.0,
          "title": "Failure Rate",
          "type": "number"
        },
        "metadata_summary": {
          "$ref": "#/$defs/CohortMetadataSummaryDto"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "stats_updated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stats Updated At"
        },
        "status": {
          "$ref": "#/$defs/ExperimentCohortStatus"
        },
        "status_counts": {
          "$ref": "#/$defs/CohortStatusCountsDto"
        },
        "total_runs": {
          "default": 0,
          "title": "Total Runs",
          "type": "integer"
        },
        "worst_score": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Worst Score"
        }
      },
      "required": [
        "cohort_id",
        "name",
        "created_at",
        "status"
      ],
      "title": "CohortSummaryDto",
      "type": "object"
    },
    "DispatchConfigSnapshot": {
      "description": "Typed snapshot of dispatch configuration relevant to cohort reproducibility.",
      "properties": {
        "extras": {
          "additionalProperties": true,
          "title": "Extras",
          "type": "object"
        },
        "max_concurrent_runs": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Concurrent Runs"
        },
        "max_questions": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Questions"
        },
        "max_retries": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Retries"
        },
        "worker_model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Worker Model"
        }
      },
      "title": "DispatchConfigSnapshot",
      "type": "object"
    },
    "ExperimentCohortStatus": {
      "description": "Experiment cohort lifecycle status.",
      "enum": [
        "active",
        "archived"
      ],
      "title": "ExperimentCohortStatus",
      "type": "string"
    },
    "SandboxConfigSnapshot": {
      "description": "Typed snapshot of sandbox configuration relevant to cohort reproducibility.",
      "properties": {
        "extras": {
          "additionalProperties": true,
          "title": "Extras",
          "type": "object"
        },
        "provider": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider"
        },
        "template_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Template Id"
        },
        "timeout_minutes": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timeout Minutes"
        }
      },
      "title": "SandboxConfigSnapshot",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Frontend-facing event emitted whenever cohort aggregate state changes.",
  "properties": {
    "cohort_id": {
      "format": "uuid",
      "title": "Cohort Id",
      "type": "string"
    },
    "summary": {
      "$ref": "#/$defs/CohortSummaryDto"
    }
  },
  "required": [
    "cohort_id",
    "summary"
  ],
  "title": "CohortUpdatedEvent",
  "type": "object"
}
