# Database (defaults to docker-compose Postgres on port 5433; override if port conflicts)
# DATABASE_URL=postgresql://h_arcane:h_arcane_dev@localhost:5433/h_arcane

# OpenAI (required for LLM judge criteria, cloud-model workers)
OPENAI_API_KEY=sk-...

# E2B Sandbox (required for tool execution in sandboxes)
E2B_API_KEY=e2b_...

# Exa search (optional, used by research benchmarks)
EXA_API_KEY=

# Shadeform (optional, for GPU provisioning via SkyPilot)
SHADEFORM_API_KEY=

# Inngest
INNGEST_EVENT_KEY=dev
INNGEST_DEV=1
INNGEST_API_BASE_URL=http://localhost:8289

# Checkpoint eval (optional; usually set by ``arcane eval watch`` subprocess, not hand-edited)
# ARCANE_CHECKPOINT_STEP=
# ARCANE_CHECKPOINT_PATH=
